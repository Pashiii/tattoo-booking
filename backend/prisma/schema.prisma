generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  isVerified   Boolean       @default(false)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  role         Role          @default(CUSTOMER)
  admin        Admin?
  customer     Customer?
  userSessions UserSession[]

  @@map("users")
}

model Customer {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  phone     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    Int       @unique
  bookings  Booking[]
  user      User      @relation(fields: [userId], references: [id])

  @@map("customers")
}

model Admin {
  id               Int            @id @default(autoincrement())
  name             String
  branchId         Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  userId           Int            @unique
  branch           Branch?        @relation(fields: [branchId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  handledBookings  Booking[]      @relation("HandledBy")
  repliedInquiries InquiryReply[]

  @@map("admins")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       Int
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  refreshToken String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Booking {
  id            Int           @id @default(autoincrement())
  referenceCode String        @unique
  branchId      Int
  artistId      Int?
  style         String
  placement     String
  size          TattooSize
  notes         String?
  preferredDate DateTime
  preferredTime String
  status        BookingStatus @default(PENDING)
  handledById   Int?
  adminNote     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customerId    Int
  artist        Artist?       @relation(fields: [artistId], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  handledBy     Admin?        @relation("HandledBy", fields: [handledById], references: [id])

  @@index([customerId])
  @@index([branchId])
  @@index([artistId])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model Inquiry {
  id        Int            @id @default(autoincrement())
  branchId  Int
  name      String
  email     String
  subject   String
  message   String
  status    InquiryStatus  @default(UNREAD)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  branch    Branch         @relation(fields: [branchId], references: [id])
  replies   InquiryReply[]

  @@index([branchId])
  @@index([status])
  @@map("inquiries")
}

model InquiryReply {
  id        Int      @id @default(autoincrement())
  inquiryId Int
  adminId   Int
  message   String
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@map("inquiry_replies")
}

model Artist {
  id           Int       @id @default(autoincrement())
  branchId     Int
  firstName    String
  lastName     String
  initials     String
  specialty    String
  bio          String?
  portfolioUrl String?
  isAvailable  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  branch       Branch    @relation(fields: [branchId], references: [id])
  bookings     Booking[]

  @@map("artists")
}

model Branch {
  id                Int       @id @default(autoincrement())
  code              String    @unique
  name              String
  address           String
  city              String
  phone             String
  email             String    @unique
  hours             String
  defaultDailyLimit Int       @default(10)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  admins            Admin[]
  artists           Artist[]
  bookings          Booking[]
  inquiries         Inquiry[]

  @@map("branches")
}

enum BookingStatus {
  PENDING
  APPROVED
  DECLINED
  COMPLETED
  CANCELLED
}

enum InquiryStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

enum Role {
  CUSTOMER
  SUPER_ADMIN
  BRANCH_ADMIN
}

enum TattooSize {
  TINY
  SMALL
  MEDIUM
  LARGE
}
